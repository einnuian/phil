# Generation backend: 'mistral' or 'anthropic'
LLM_PROVIDER=mistral

OPENAI_API_KEY=sk-...          # always required (document embeddings)
MISTRAL_API_KEY=...            # required when LLM_PROVIDER=mistral
ANTHROPIC_API_KEY=sk-ant-...   # required when LLM_PROVIDER=anthropic

# CORS for the web API (api/server.py). Which frontend origins may call the backend.
# Comma-separated list of exact origins. Defaults to http://localhost:3000 if unset.
ALLOWED_ORIGINS=http://localhost:3000
# Optional regex allowing a family of origins on top of the list above — handy for
# Vercel preview deployments (unique URL per branch). Leave blank to disable.
# Example: ALLOWED_ORIGIN_REGEX=https://cisv-rag-.*\.vercel\.app
ALLOWED_ORIGIN_REGEX=
